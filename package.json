{
  "name": "echoes-of-beast",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Echoes of Beast — an original monster-taming turn-based RPG (Web/PWA).",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test"
  },
  "dependencies": {
    "phaser": "4.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^26.0.0",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "eslint": "^9.12.0",
    "fake-indexeddb": "^6.0.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vite-plugin-pwa": "^0.20.5",
    "vitest": "^2.1.0"
  }
}
